{
    "cli": {
        "--": {
            "pointer": "/nodes/image/properties/path",
            "required": true
        }
    },
    "graph_properties": {
        "flush thread pool": true,
        "fps limiter": false,
        "iterations in flight": 2,
        "low latency": false,
        "time overwrite": "None"
    },
    "nodes": {
        "blit": {
            "enabled": true,
            "outputs": [
                "acquire->imgui.acquire"
            ],
            "type": "Swapchain Blit"
        },
        "image": {
            "enabled": true,
            "outputs": [
                "out->tonemap.src"
            ],
            "properties": {
                "path": ""
            },
            "type": "HDR Image"
        },
        "imgui": {
            "enabled": true,
            "type": "ImGui"
        },
        "tonemap": {
            "enabled": true,
            "outputs": [
                "out->blit.src"
            ],
            "properties": {
                "exposure bias": 2.0,
                "tonemap": "Uncharted 2"
            },
            "type": "Tonemap"
        },
        "window": {
            "enabled": true,
            "outputs": [
                "acquire->blit.acquire",
                "window->imgui.window"
            ],
            "properties": {
                "backend": "SDL3 (Video Subsystem)",
                "blit mode": "FIT",
                "on_should_close_actions": {
                    "remove node": false,
                    "send sigint": true,
                    "send sigterm": false
                },
                "present mode": "Fifo"
            },
            "type": "Window"
        }
    },
    "version": 4
}
