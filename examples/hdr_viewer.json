{
    "graph_properties": {
        "flush thread pool": true,
        "fps limiter": true,
        "iterations in flight": 2,
        "low latency": false,
        "short_config": {
            "--": {
                "pointer": "/nodes/0/properties/path",
                "required": true
            }
        },
        "time overwrite": "None"
    },
    "nodes": [
        {
            "enabled": true,
            "id": "image",
            "type": "HDR Image",
            "outputs": [
                "out->tonemap.src"
            ],
            "properties": {
                "path": ""
            }
        },
        {
            "enabled": true,
            "id": "tonemap",
            "type": "Tonemap",
            "outputs": [
                "out->blit.src"
            ],
            "properties": {
                "tonemap": "Uncharted 2",
                "exposure bias": 2.0
            }
        },
        {
            "enabled": true,
            "id": "blit",
            "type": "Swapchain Blit",
            "outputs": [
                "acquire->imgui.acquire"
            ]
        },
        {
            "enabled": true,
            "id": "window",
            "type": "Window",
            "outputs": [
                "acquire->blit.acquire",
                "window->imgui.window"
            ],
            "properties": {
                "backend": "SDL3 (Video Subsystem)",
                "blit mode": "FIT"
            }
        },
        {
            "enabled": true,
            "id": "imgui",
            "type": "ImGui"
        }
    ],
    "version": 3
}
