{
    "cli": {
        "--": {
            "pointer": "/nodes/shadertoy/properties/shader path",
            "required": true
        }
    },
    "graph_properties": {
        "flush thread pool": true,
        "fps limiter": false,
        "iterations in flight": 2,
        "low latency": false,
        "time overwrite": "None"
    },
    "nodes": {
        "blit": {
            "enabled": true,
            "outputs": [
                "acquire->imgui.acquire"
            ],
            "type": "Swapchain Blit"
        },
        "imgui": {
            "enabled": true,
            "type": "ImGui"
        },
        "shadertoy": {
            "enabled": true,
            "outputs": [
                "out->blit.src"
            ],
            "properties": {
                "height": 720,
                "shader path": "",
                "shader source": "file",
                "width": 1280
            },
            "type": "Shadertoy"
        },
        "window": {
            "enabled": true,
            "outputs": [
                "acquire->blit.acquire",
                "controller->shadertoy.controller",
                "window->imgui.window"
            ],
            "properties": {
                "backend": "SDL3 (Video Subsystem)",
                "blit mode": "FIT",
                "on_should_close_actions": {
                    "remove node": false,
                    "send sigint": true,
                    "send sigterm": false
                },
                "present mode": "Immediate"
            },
            "type": "Window"
        }
    },
    "version": 4
}
